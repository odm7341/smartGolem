scoreboard players set $found sg_guide 0
$execute if score #debug sg_config matches 1 run tellraw @a [{"text":"[Smart Golem Debug]  ","color":"gold"},{"text":"Searching memory for UUID=$(gu) item=$(item)","color":"gray"}]
$execute if data storage smart_golem:brain.list [{uuid:$(gu),item:"$(item)"}] run execute store result score $target_x sg_guide run data get storage smart_golem:brain.list [{uuid:$(gu),item:"$(item)"}].pos[0]
$execute if data storage smart_golem:brain.list [{uuid:$(gu),item:"$(item)"}] run execute store result score $target_y sg_guide run data get storage smart_golem:brain.list [{uuid:$(gu),item:"$(item)"}].pos[1]
$execute if data storage smart_golem:brain.list [{uuid:$(gu),item:"$(item)"}] run execute store result score $target_z sg_guide run data get storage smart_golem:brain.list [{uuid:$(gu),item:"$(item)"}].pos[2]
$execute if data storage smart_golem:brain.list [{uuid:$(gu),item:"$(item)"}] run scoreboard players set $found sg_guide 1
execute if score $found sg_guide matches 1 run execute store result storage smart_golem:macro target_x int 1 run scoreboard players get $target_x sg_guide
execute if score $found sg_guide matches 1 run execute store result storage smart_golem:macro target_y int 1 run scoreboard players get $target_y sg_guide
execute if score $found sg_guide matches 1 run execute store result storage smart_golem:macro target_z int 1 run scoreboard players get $target_z sg_guide
